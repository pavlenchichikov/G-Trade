# Normalize line endings: store as LF in the repo, check out native on Windows.
# Stops the constant "LF will be replaced by CRLF" churn in diffs.
* text=auto eol=lf

# cmd.exe requires CRLF: LF-only batch files misparse (set /p, if-blocks).
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary artifacts: never touch.
*.cbm  binary
*.keras binary
*.h5   binary
*.pkl  binary
*.db   binary
*.png  binary
*.jpg  binary
*.ico  binary
