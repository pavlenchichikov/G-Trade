# G-Trade - Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Telegram Bot (create via @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_USER_ID=your_telegram_user_id_here

# Proxy settings (optional - for Yahoo Finance / Telegram behind firewall).
# Leave SOCKS5_PROXY empty to connect directly.
SOCKS5_PROXY=
# Proxy mode: auto (probe) | on | off
GTRADE_PROXY_MODE=auto

# TLS certificate verification for outbound requests.
# Default on (secure). Set to 0 only if a TLS-intercepting proxy breaks fetches.
GTRADE_SSL_VERIFY=1
