# Скопируй в .env и заполни:
#   cp .env.example .env

# Телеграм-бот (создаётся через @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_USER_ID=your_telegram_user_id_here

# SOCKS5-прокси для исходящих запросов. Пусто = напрямую.
SOCKS5_PROXY=
# Режим прокси: auto (проба) | on | off
GTRADE_PROXY_MODE=auto

# Проверка TLS-сертификатов. По умолчанию включена,
# ставь 0 только если прокси перехватывает TLS.
GTRADE_SSL_VERIFY=1

# Час отправки утреннего дайджеста ботом
GTRADE_DIGEST_HOUR=9

# Atratus live-signals push (push_signals.py) - service key is SECRET, local only
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Path to the Firebase service-account JSON for mobile push notifications
# (secret - keep outside git). Leave unset to skip pushes entirely.
GTRADE_FCM_CREDS=
